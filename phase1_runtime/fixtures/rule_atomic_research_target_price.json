{
  "rule_id": "atomic.research_target_price.v1",
  "name": "Research report target price and valuation extraction",
  "status": "published",
  "version": "v1",
  "rule_kind": "atomic",
  "rule_family": "equity_research",
  "trigger": {
    "query_signals": ["目标价", "估值", "PB", "PE", "上涨空间", "目标", "空间"],
    "question_types": ["analysis_query"],
    "intents": ["extract", "summarize"]
  },
  "applicability": {
    "document_types": ["report"],
    "scope": "适用于从股票研报中提取目标价、估值方法及上涨空间。",
    "non_scope": "不适用于无明确目标价的宏观报告或行业报告。"
  },
  "inputs": {
    "required": [
      {
        "key": "target_price",
        "type": "number",
        "description": "目标价（数字，单位：元）",
        "hints": ["目标价", "上涨空间", "价格"]
      },
      {
        "key": "valuation_method",
        "type": "string",
        "description": "估值方法（如PB、PE、DCF等）",
        "hints": ["PB", "PE", "估值", "倍", "×"]
      }
    ],
    "optional": []
  },
  "steps": [
    {
      "step_id": "extract_target_price",
      "type": "extract",
      "goal": "从研报文档中提取分析师给出的目标价（具体数字，单位元）。如有多个目标价（如短期/长期），提取最主要的那个。",
      "depends_on": [],
      "io": {
        "inputs": [],
        "outputs": [
          {"key": "target_price", "type": "number", "description": "目标价（元）"},
          {"key": "evidence_refs", "type": "array", "description": "原文出处"}
        ]
      },
      "executor": {"mode": "llm", "allowed_tools": []},
      "constraints": {
        "must_use_evidence": true,
        "hints": ["目标价", "上涨空间", "PB", "PE", "估值"],
        "chunk_top_k": 8
      }
    },
    {
      "step_id": "extract_valuation_basis",
      "type": "extract",
      "goal": "从研报文档中提取估值方法（如PB法、PE法、DCF等）、所用估值倍数（如0.75× 2026E PB）及上涨空间描述（如'+13%空间'）。",
      "depends_on": [],
      "io": {
        "inputs": [],
        "outputs": [
          {"key": "valuation_method", "type": "string", "description": "估值方法（PB/PE/DCF等）"},
          {"key": "valuation_multiple", "type": "string", "description": "所用估值倍数及预测年份"},
          {"key": "upside_description", "type": "string", "description": "上涨空间描述"},
          {"key": "evidence_refs", "type": "array", "description": "原文出处"}
        ]
      },
      "executor": {"mode": "llm", "allowed_tools": []},
      "constraints": {
        "must_use_evidence": true,
        "hints": ["PB", "PE", "估值", "倍", "×", "空间"],
        "chunk_top_k": 8
      }
    },
    {
      "step_id": "build_valuation_answer",
      "type": "explain",
      "goal": "综合目标价、估值方法和上涨空间，生成完整的估值分析摘要。decision字段：若上涨空间>15%填upside_high；5%-15%填upside_moderate；<5%或下行填upside_low。",
      "depends_on": ["extract_target_price", "extract_valuation_basis"],
      "io": {
        "inputs": [
          "$step.extract_target_price.output.target_price",
          "$step.extract_valuation_basis.output.valuation_method",
          "$step.extract_valuation_basis.output.valuation_multiple",
          "$step.extract_valuation_basis.output.upside_description"
        ],
        "outputs": [
          {"key": "target_price", "type": "number", "description": "目标价（元）"},
          {"key": "valuation_method", "type": "string", "description": "估值方法"},
          {"key": "valuation_multiple", "type": "string", "description": "估值倍数"},
          {"key": "upside_description", "type": "string", "description": "上涨空间"},
          {"key": "answer_text", "type": "string", "description": "完整估值分析摘要"},
          {"key": "decision", "type": "string", "description": "upside_high / upside_moderate / upside_low"},
          {"key": "evidence_refs", "type": "array", "description": "原文出处"}
        ]
      },
      "executor": {"mode": "llm", "allowed_tools": []},
      "constraints": {
        "must_use_evidence": true,
        "chunk_top_k": 8
      }
    }
  ],
  "outputs": {
    "answer_schema": {
      "type": "object",
      "required": ["target_price", "valuation_method", "answer_text", "decision", "evidence_refs"],
      "properties": {
        "target_price": {"type": "number"},
        "valuation_method": {"type": "string"},
        "valuation_multiple": {"type": "string"},
        "upside_description": {"type": "string"},
        "answer_text": {"type": "string"},
        "decision": {"type": "string"},
        "evidence_refs": {"type": "array"}
      }
    },
    "must_include": ["target_price", "answer_text", "decision", "evidence_refs"]
  },
  "validators": [
    {
      "validator_id": "schema.validate",
      "target": "final",
      "severity": "error"
    },
    {
      "validator_id": "evidence.required",
      "target": "final",
      "severity": "error"
    }
  ],
  "provenance": {
    "source_cases": [],
    "review": {
      "review_status": "approved",
      "reviewer": "rule_factory",
      "reviewed_at": "2026-04-03T00:00:00+00:00"
    }
  }
}
