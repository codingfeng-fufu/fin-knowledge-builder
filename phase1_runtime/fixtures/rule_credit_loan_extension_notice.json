{
  "rule_id": "credit.loan_extension_notice.v1",
  "name": "Credit loan extension notice",
  "status": "published",
  "version": "v1",
  "trigger": {
    "query_signals": ["展期", "续贷", "通知", "到期", "借款人"],
    "question_types": ["policy_check"],
    "intents": ["compare", "judge"]
  },
  "applicability": {
    "document_types": ["contract", "policy"],
    "scope": "适用于贷款展期是否需要向借款人发送通知的判断。",
    "non_scope": "不适用于私募基金净值跌破阈值后的风险提示场景。"
  },
  "inputs": {
    "required": [
      {
        "key": "days_to_maturity",
        "type": "number",
        "description": "Days remaining until loan maturity.",
        "hints": ["到期", "还有", "剩余", "天", "距离到期"]
      },
      {
        "key": "notice_threshold_days",
        "type": "number",
        "description": "Contractual notice window in days before maturity.",
        "hints": ["通知", "前", "日", "天", "到期前", "展期"]
      },
      {
        "key": "contract_requires_notice",
        "type": "boolean",
        "description": "Whether the contract requires borrower notification.",
        "hints": ["通知", "应通知", "合同约定", "借款人", "展期手续"]
      }
    ],
    "optional": []
  },
  "steps": [
    {
      "step_id": "extract_days_to_maturity",
      "type": "extract",
      "goal": "从文档中找到贷款距离到期还有多少天（整数）。",
      "depends_on": [],
      "io": {
        "inputs": [],
        "outputs": [
          {"key": "days_to_maturity", "type": "number", "description": "Days to maturity."},
          {"key": "evidence_refs", "type": "array", "description": "Evidence pointers."}
        ]
      },
      "executor": {"mode": "llm", "allowed_tools": []},
      "constraints": {"must_use_evidence": true}
    },
    {
      "step_id": "extract_notice_threshold_days",
      "type": "extract",
      "goal": "从文档中找到合同约定的通知窗口天数（整数，如到期前X日中的X）。",
      "depends_on": [],
      "io": {
        "inputs": [],
        "outputs": [
          {"key": "notice_threshold_days", "type": "number", "description": "Notice threshold days."},
          {"key": "evidence_refs", "type": "array", "description": "Evidence pointers."}
        ]
      },
      "executor": {"mode": "llm", "allowed_tools": []},
      "constraints": {"must_use_evidence": true}
    },
    {
      "step_id": "extract_contract_requires_notice",
      "type": "extract",
      "goal": "从文档中判断合同是否约定须通知借款人办理展期手续（布尔值）。",
      "depends_on": [],
      "io": {
        "inputs": [],
        "outputs": [
          {"key": "contract_requires_notice", "type": "boolean", "description": "Whether contract requires notice."},
          {"key": "evidence_refs", "type": "array", "description": "Evidence pointers."}
        ]
      },
      "executor": {"mode": "llm", "allowed_tools": []},
      "constraints": {"must_use_evidence": true}
    },
    {
      "step_id": "check_notice_window",
      "type": "judge",
      "goal": "Determine whether the loan has entered the contractual notice window before maturity.",
      "depends_on": ["extract_days_to_maturity", "extract_notice_threshold_days"],
      "io": {
        "inputs": [
          "$step.extract_days_to_maturity.output.days_to_maturity",
          "$step.extract_notice_threshold_days.output.notice_threshold_days"
        ],
        "outputs": [
          {"key": "notice_window_open", "type": "boolean", "description": "Whether within notice window."},
          {"key": "left_value", "type": "number", "description": "Days to maturity."},
          {"key": "right_value", "type": "number", "description": "Notice threshold."},
          {"key": "operator", "type": "string", "description": "Comparison operator."},
          {"key": "evidence_refs", "type": "array", "description": "Evidence pointers."}
        ]
      },
      "executor": {
        "mode": "tool",
        "tool": "compare_numeric",
        "allowed_tools": ["compare_numeric"],
        "config": {
          "left_key": "days_to_maturity",
          "right_key": "notice_threshold_days",
          "operator": "<=",
          "result_key": "notice_window_open",
          "evidence_snippet_ids": ["snippet_notice_clause", "snippet_maturity_schedule"]
        }
      },
      "constraints": {"must_use_evidence": true}
    },
    {
      "step_id": "check_notice_requirement",
      "type": "judge",
      "goal": "Determine whether the contractually required borrower notice should now be sent.",
      "depends_on": ["check_notice_window", "extract_contract_requires_notice"],
      "io": {
        "inputs": [
          "$step.check_notice_window.output.notice_window_open",
          "$step.extract_contract_requires_notice.output.contract_requires_notice"
        ],
        "outputs": [
          {"key": "notice_required", "type": "boolean", "description": "Whether notice must be sent."},
          {"key": "checked_inputs", "type": "object", "description": "Inputs evaluated."},
          {"key": "evidence_refs", "type": "array", "description": "Evidence pointers."}
        ]
      },
      "executor": {
        "mode": "tool",
        "tool": "boolean_gate",
        "allowed_tools": ["boolean_gate"],
        "config": {
          "input_keys": ["notice_window_open", "contract_requires_notice"],
          "mode": "all_true",
          "result_key": "notice_required",
          "evidence_snippet_ids": ["snippet_notice_clause", "snippet_maturity_schedule"]
        }
      },
      "constraints": {"must_use_evidence": true}
    },
    {
      "step_id": "build_final_notice_answer",
      "type": "explain",
      "goal": "Build the final answer payload for the borrower-notice decision.",
      "depends_on": ["check_notice_requirement", "extract_contract_requires_notice"],
      "io": {
        "inputs": [
          "$step.check_notice_window.output.notice_window_open",
          "$step.check_notice_requirement.output.notice_required",
          "$step.extract_contract_requires_notice.output.contract_requires_notice"
        ],
        "outputs": [
          {"key": "answer_text", "type": "string", "description": "Human-readable answer."},
          {"key": "decision", "type": "string", "description": "Machine-readable decision code."},
          {"key": "notice_window_open", "type": "boolean", "description": "Whether within notice window."},
          {"key": "notice_required", "type": "boolean", "description": "Whether notice required."},
          {"key": "explanation", "type": "string", "description": "Explanation."},
          {"key": "evidence_refs", "type": "array", "description": "Evidence pointers."}
        ]
      },
      "executor": {
        "mode": "tool",
        "tool": "build_notice_answer",
        "allowed_tools": ["build_notice_answer"],
        "config": {
          "decision_input_key": "notice_required",
          "window_input_key": "notice_window_open",
          "positive_text": "需要发送展期通知，因为已进入合同约定的通知窗口，且合同明确要求通知借款人办理展期手续。",
          "negative_text": "当前不需要发送展期通知，因为尚未进入通知窗口或合同未要求通知借款人办理展期手续。",
          "positive_decision": "must_notify",
          "negative_decision": "no_notice_required",
          "evidence_snippet_ids": ["snippet_notice_clause", "snippet_maturity_schedule"]
        }
      },
      "constraints": {"must_use_evidence": true}
    }
  ],
  "outputs": {
    "answer_schema": {
      "type": "object",
      "required": ["answer_text", "decision", "notice_window_open", "notice_required", "explanation", "evidence_refs"],
      "properties": {
        "answer_text": {"type": "string"},
        "decision": {"type": "string"},
        "notice_window_open": {"type": "boolean"},
        "notice_required": {"type": "boolean"},
        "explanation": {"type": "string"},
        "evidence_refs": {"type": "array"}
      }
    },
    "must_include": ["answer_text", "decision", "evidence_refs"]
  },
  "validators": [
    {"validator_id": "schema.validate", "target": "step:check_notice_window", "severity": "error"},
    {"validator_id": "schema.validate", "target": "step:check_notice_requirement", "severity": "error"},
    {"validator_id": "schema.validate", "target": "step:build_final_notice_answer", "severity": "error"},
    {"validator_id": "schema.validate", "target": "final", "severity": "error"},
    {"validator_id": "evidence.required", "target": "final", "severity": "error"},
    {
      "validator_id": "must_include",
      "target": "final",
      "severity": "error",
      "params": {"fields": ["answer_text", "decision", "evidence_refs"]}
    }
  ],
  "provenance": {
    "source_cases": ["case_credit_loan_extension_notice_001"],
    "review": {
      "review_status": "approved",
      "reviewer": "demo_reviewer",
      "reviewed_at": "2026-03-23T00:00:00Z"
    }
  }
}
