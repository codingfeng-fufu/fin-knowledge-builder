  ],
  "outputs": {
    "answer_schema": {
      "type": "object",
      "required": ["target_price", "valuation_method", "valuation_multiple", "upside_description", "answer_text", "decision", "evidence_refs"],
      "properties": {
        "target_price": {"type": "number"},
        "valuation_method": {"type": "string"},
        "valuation_multiple": {"type": "string"},
        "upside_description": {"type": "string"},
        "answer_text": {"type": "string"},
        "decision": {"type": "string"},
        "evidence_refs": {"type": "array"}
