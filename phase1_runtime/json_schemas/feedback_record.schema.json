{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "feedback_record.schema.json",
  "type": "object",
  "properties": {
    "feedback_id": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "case_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "rule_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "route_decision": {
      "type": "string"
    },
    "feedback_type": {
      "type": "string"
    },
    "payload": {
      "type": "object",
      "additionalProperties": true
    },
    "created_at": {
      "type": "string"
    }
  },
  "required": [
    "feedback_id",
    "trace_id",
    "case_id",
    "rule_ids",
    "route_decision",
    "feedback_type",
    "payload",
    "created_at"
  ],
  "additionalProperties": false
}